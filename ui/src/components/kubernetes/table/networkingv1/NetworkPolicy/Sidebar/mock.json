{
  "apiVersion": "networking.k8s.io/v1",
  "kind": "NetworkPolicy",
  "metadata": {
    "name": "web-allow-ingress",
    "namespace": "production",
    "uid": "np-12345-abcde-67890",
    "resourceVersion": "129834",
    "creationTimestamp": "2025-08-02T14:12:09Z",
    "labels": {
      "app.kubernetes.io/managed-by": "Helm",
      "app.kubernetes.io/part-of": "frontend"
    },
    "annotations": {
      "meta.helm.sh/release-name": "frontend",
      "meta.helm.sh/release-namespace": "production"
    }
  },
  "spec": {
    "podSelector": {
      "matchLabels": {
        "app": "frontend",
        "tier": "web"
      },
      "matchExpressions": [
        {
          "key": "environment",
          "operator": "In",
          "values": ["production", "staging"]
        }
      ]
    },
    "policyTypes": ["Ingress", "Egress"],
    "ingress": [
      {
        "from": [
          {
            "podSelector": {
              "matchLabels": {
                "role": "api-gateway"
              }
            }
          },
          {
            "namespaceSelector": {
              "matchLabels": {
                "purpose": "monitoring"
              }
            },
            "podSelector": {
              "matchLabels": {
                "app": "prometheus"
              }
            }
          },
          {
            "ipBlock": {
              "cidr": "172.17.0.0/16",
              "except": ["172.17.1.0/24", "172.17.2.0/24"]
            }
          }
        ],
        "ports": [
          { "protocol": "TCP", "port": 80 },
          { "protocol": "TCP", "port": 443 },
          { "protocol": "TCP", "port": 8080, "endPort": 8090 }
        ]
      },
      {
        "from": [
          {
            "podSelector": {
              "matchLabels": {
                "app": "health-checker"
              }
            }
          }
        ],
        "ports": [
          { "protocol": "TCP", "port": 8081 }
        ]
      }
    ],
    "egress": [
      {
        "to": [
          {
            "podSelector": {
              "matchLabels": {
                "app": "backend-api",
                "tier": "api"
              }
            }
          }
        ],
        "ports": [
          { "protocol": "TCP", "port": 3000 }
        ]
      },
      {
        "to": [
          {
            "ipBlock": {
              "cidr": "10.0.0.0/8"
            }
          }
        ],
        "ports": [
          { "protocol": "TCP", "port": 5432 },
          { "protocol": "TCP", "port": 6379 }
        ]
      },
      {
        "to": [
          {
            "namespaceSelector": {
              "matchLabels": {
                "kubernetes.io/metadata.name": "kube-system"
              }
            }
          }
        ],
        "ports": [
          { "protocol": "UDP", "port": 53 },
          { "protocol": "TCP", "port": 53 }
        ]
      }
    ]
  }
}
